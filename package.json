{
  "name": "@minion-stack/drone",
  "version": "0.5.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikolasP98/drone.git"
  },
  "description": "Minion's mini-agent primitive and interactive workspace Drone runtime.",
  "license": "MIT",
  "files": [
    "dist",
    "docs",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "drone": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.3.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "baml:generate": "baml-cli generate --from baml_src",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "build:release": "pnpm clean && pnpm baml:generate && tsc -p tsconfig.build.json",
    "dev": "bun src/cli.ts",
    "prepack": "pnpm build:release",
    "test": "vitest run",
    "test:live": "vitest run --config vitest.live.config.ts",
    "typecheck": "tsc --noEmit",
    "verify:package": "node scripts/verify-package.mjs"
  },
  "devDependencies": {
    "@boundaryml/baml": "^0.84.0",
    "@earendil-works/pi-ai": "0.75.5",
    "@sinclair/typebox": "0.34.48",
    "typescript": "^5.5.0",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@boundaryml/baml": "^0.84.0",
    "@earendil-works/pi-ai": "0.75.5",
    "@sinclair/typebox": "0.34.48"
  },
  "dependencies": {
    "@opentui/core": "0.4.3",
    "web-tree-sitter": "0.25.10"
  }
}
