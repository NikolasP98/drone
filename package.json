{
  "name": "@nikolasp98/drone",
  "version": "0.2.0",
  "description": "Middle-tier mini-agent primitive: isolated LLM call with own model, system prompt, tools, and skills. Sits between forcedToolCall and runEmbeddedPiAgent.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "baml:generate": "baml-cli generate --from baml_src",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:live": "vitest run --config vitest.live.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@boundaryml/baml": "^0.84.0",
    "@earendil-works/pi-ai": "0.75.5",
    "@sinclair/typebox": "0.34.48",
    "typescript": "^5.5.0",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@boundaryml/baml": "*",
    "@earendil-works/pi-ai": "*",
    "@sinclair/typebox": "*"
  }
}
